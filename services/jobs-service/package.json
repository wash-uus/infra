{
  "name": "@infra/jobs-service",
  "version": "1.0.0",
  "private": true,
  "description": "InfraSells Jobs microservice — job listings, applications, and AI match scoring",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
