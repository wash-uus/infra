{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"],
    "typeRoots": ["../../nodejs-backend/node_modules/@types", "../../nodejs-backend/node_modules"],
    "paths": {
      "firebase-admin": ["../../nodejs-backend/node_modules/firebase-admin"],
      "firebase-admin/*": ["../../nodejs-backend/node_modules/firebase-admin/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
