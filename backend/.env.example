SECRET_KEY=replace-me
DEBUG=False

# ── Truehost cPanel production values ──────────────────────────────────────
# Server IP: 141.95.45.75  |  cPanel: http://141.95.45.75:2082/
ALLOWED_HOSTS=spiritrevivalafrica.com,www.spiritrevivalafrica.com,api.spiritrevivalafrica.com,141.95.45.75

# MySQL database created in cPanel → MySQL Databases
# Format: mysql://cpanel_user:password@localhost/cpanel_user_dbname
DATABASE_URL=mysql://bttpuwwh:DB_PASSWORD@localhost/bttpuwwh_sra

REDIS_URL=

CORS_ALLOWED_ORIGINS=https://spiritrevivalafrica.com,https://www.spiritrevivalafrica.com

# Truehost SMTP — create an email account in cPanel first
EMAIL_HOST=lim117.truehost.cloud
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@spiritrevivalafrica.com
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@spiritrevivalafrica.com

FRONTEND_URL=https://spiritrevivalafrica.com
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# ── Africa's Talking — SMS welcome & approval notifications ────────────────
# Free sign-up: https://account.africastalking.com/
# Step 1: Register → go to Sandbox → copy your API Key from the sandbox dashboard
# Step 2: Set AT_USERNAME=sandbox  and  AT_API_KEY=<sandbox key>  to test for FREE
# Step 3: When ready for live SMS, top up as little as KSH 10, set your real username + live API key
#
# Sandbox simulator: https://simulator.africastalking.com/
# (Messages in sandbox mode show up in the simulator, NOT on real phones — perfect for dev)
AT_USERNAME=sandbox
AT_API_KEY=
# Optional: alphanumeric sender ID shown on recipients' phones (max 11 chars, approved by AT)
AT_SENDER_ID=SRA

# ── Image storage (local | s3 | cloudinary) ────────────────────────────────
MEDIA_STORAGE=local

# AWS S3 (when MEDIA_STORAGE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# Cloudinary (when MEDIA_STORAGE=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Auto-fetch hero photos ─────────────────────────────────────────────────
# Get free keys from https://www.pexels.com/api/  and  https://unsplash.com/developers
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
# Max images returned by /api/hero-collage/ (default 24)
HERO_MAX_COLLAGE_ITEMS=24

